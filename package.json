{
  "name": "beta",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "dev": "turbo dev",
    "dev:server": "turbo -F server dev",
    "dev:web": "turbo -F web dev",
    "build": "turbo build",
    "build:server": "turbo -F server build",
    "build:web": "turbo -F web build",
    "start": "turbo start",
    "start:server": "turbo -F server start",
    "start:web": "turbo -F web start",
    "db:push": "turbo -F @app/infra db:push",
    "db:generate": "turbo -F @app/infra db:generate",
    "db:migrate": "turbo -F @app/infra db:migrate",
    "db:seed": "bun scripts/seed.ts",
    "db:studio": "turbo -F @app/infra db:studio",
    "lint": "bun ultracite check",
    "lint:fix": "bun ultracite fix",
    "lint:fix:unsafe": "bun ultracite fix --unsafe",
    "check-types": "turbo check-types",
    "ci": "bun lint && bun check-types && bun run build",
    "env": "bun scripts/env.ts",
    "railway": "bun scripts/railway.ts",
    "cleanup": "bun scripts/cleanup.ts"
  },
  "catalog": {
    "@types/bun": "latest",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "turbo": "^2.8.12"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "@biomejs/biome": "2.3.14",
    "@clack/prompts": "^1.0.1",
    "@types/bun": "catalog:",
    "picocolors": "^1.1.1",
    "typescript": "catalog:",
    "ultracite": "7.1.5"
  }
}
